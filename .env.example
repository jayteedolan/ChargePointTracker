# ChargePoint Monitor — configuration template
# Copy to .env and fill in your values. Never commit .env to git.

# --- ChargePoint credentials ---
# Your ChargePoint account email and password (same as the mobile app)
CHARGEPOINT_USERNAME=your@email.com
CHARGEPOINT_PASSWORD=yourpassword

# Station ID from the ChargePoint URL (the integer in the URL when viewing your station)
# e.g. https://www.chargepoint.com/stations/12345 → use 12345
CHARGEPOINT_STATION_ID=123456

# --- ntfy.sh notifications ---
# Pick a long, random topic name — this acts as a shared secret.
# Subscribe to this topic in the ntfy app on your phone.
# Example: chargepoint-monitor-xk9q2mfp
NTFY_TOPIC=change-me-to-something-random

# ntfy server URL (leave as-is for the public server)
NTFY_URL=https://ntfy.sh

# --- App settings ---
# Port the web app listens on. Pick any unused port.
# Example: 8765 for this service, leaving 8080/3000/5000/etc free for other services.
APP_PORT=8765

# How often to poll ChargePoint for updates (seconds). Recommended: 120
POLL_INTERVAL_SECONDS=120

# --- Network ---
# Your Pi's LAN IP address or DDNS hostname.
# Used in ntfy notification action buttons ("Stop Watching").
# If you've set up port forwarding, use your external IP/hostname instead
# so the button works from anywhere.
# Example (LAN only): 192.168.1.42
# Example (external): myhome.duckdns.org
PI_HOST=192.168.1.x
